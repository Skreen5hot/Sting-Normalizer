{
  "name": "PascalCase / WikiWords splits on lower-to-upper boundary",
  "task": {
    "@type": "NormalizationTask",
    "rawIdentifier": "UserProfileAddress",
    "pipeline": {
      "@type": "PipelineDefinition",
      "rules": [
        {
          "@type": "Rule",
          "phase": "Transformation",
          "order": 10,
          "ruleKind": "RegexReplace",
          "pattern": "([a-z0-9])([A-Z])",
          "flags": "g",
          "replacement": "$1 $2"
        }
      ]
    }
  },
  "expected": {
    "status": "succeeded",
    "tokens": ["user", "profile", "address"],
    "normalizedString": "user profile address",
    "warningCodes": []
  }
}
